<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".CreateHistoryActivity">

    <TextView
        android:id="@+id/tv_create_history_header"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="8dp"
        android:layout_marginTop="8dp"
        android:text="@string/create_history_header"
        android:textSize="24sp"
        android:textStyle="bold"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/tv_learned_date_label"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="8dp"
        android:layout_marginTop="8dp"
        android:text="@string/tv_learned_date"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/tv_create_history_header" />

    <TextView
        android:id="@+id/tv_correct_number"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="8dp"
        android:text="@string/tv_correct_number"
        app:layout_constraintBaseline_toBaselineOf="@+id/et_correct_number"
        app:layout_constraintStart_toStartOf="parent" />

    <TextView
        android:id="@+id/tv_entire_number"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="8dp"
        android:text="@string/tv_entire_number"
        app:layout_constraintBaseline_toBaselineOf="@+id/et_entire_number"
        app:layout_constraintStart_toStartOf="parent" />

    <EditText
        android:id="@+id/et_correct_number"
        android:layout_width="48dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="8dp"
        android:layout_marginTop="8dp"
        android:ems="10"
        android:inputType="number"
        android:minHeight="48dp"
        app:layout_constraintStart_toEndOf="@+id/tv_correct_number"
        app:layout_constraintTop_toBottomOf="@+id/tv_learned_date"
        tools:ignore="Autofill,DuplicateSpeakableTextCheck" />

    <EditText
        android:id="@+id/et_entire_number"
        android:layout_width="48dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="8dp"
        android:layout_marginTop="8dp"
        android:ems="10"
        android:inputType="number"
        android:minHeight="48dp"
        app:layout_constraintStart_toEndOf="@+id/tv_entire_number"
        app:layout_constraintTop_toBottomOf="@+id/et_correct_number"
        tools:ignore="Autofill" />

    <TextView
        android:id="@+id/tv_correct_number_unit"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="8dp"
        android:text="@string/tv_quiz_unit"
        app:layout_constraintBaseline_toBaselineOf="@+id/et_correct_number"
        app:layout_constraintStart_toEndOf="@+id/et_correct_number" />

    <TextView
        android:id="@+id/tv_entire_number_unit"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="8dp"
        android:text="@string/tv_quiz_unit"
        app:layout_constraintBaseline_toBaselineOf="@+id/et_entire_number"
        app:layout_constraintStart_toEndOf="@+id/et_entire_number" />

    <Button
        android:id="@+id/btn_create_history"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="8dp"
        android:layout_marginTop="8dp"
        android:layout_marginEnd="8dp"
        android:onClick="onCreateBtnClick"
        android:text="@string/btn_create_history"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/et_entire_number"
        tools:ignore="VisualLintButtonSize" />

    <TextView
        android:id="@+id/tv_learned_date"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="8dp"
        android:layout_marginTop="8dp"
        app:layout_constraintStart_toEndOf="@+id/tv_learned_date_label"
        app:layout_constraintTop_toBottomOf="@+id/tv_create_history_header" />

    <TextView
        android:id="@+id/tv_learned_time"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="8dp"
        android:layout_marginTop="8dp"
        app:layout_constraintStart_toEndOf="@+id/tv_learned_date"
        app:layout_constraintTop_toBottomOf="@+id/tv_create_history_header" />

</androidx.constraintlayout.widget.ConstraintLayout>